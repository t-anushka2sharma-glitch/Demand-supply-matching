    {
      "name": "Edit & Cancel (PUT/DELETE)",
      "item": [
        {
          "name": "1. Add a fresh supply order (tomato 24/kg 100kg) -> captures edit_s_id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('edit_s_id', body.orderId);",
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('PENDING, no trades', () => { pm.expect(body.status).to.eql('PENDING'); pm.expect(body.tradesGenerated.length).to.eql(0); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/orders/supply",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"time\": \"09:45\",\n  \"produce\": \"tomato\",\n  \"price\": 24,\n  \"quantity\": 100\n}"
            }
          }
        },
        {
          "name": "2. PUT edit_s_id -> lower price to 18/kg, raise quantity to 120kg",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('price and quantity updated', () => { pm.expect(body.price).to.eql(18); pm.expect(body.quantity).to.eql(120); });"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/orders/{{edit_s_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 18,\n  \"quantity\": 120\n}"
            }
          }
        },
        {
          "name": "3. Status of edit_s_id -> confirm still PENDING with the new price/quantity",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/orders/{{edit_s_id}}/status"
          }
        },
        {
          "name": "4. Add a demand order (tomato 20/kg 50kg) -> matches edit_s_id at its NEW 18/kg price",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('edit_d_id', body.orderId);",
                  "pm.test('one trade at the edited price (18/kg)', () => { pm.expect(body.tradesGenerated.length).to.eql(1); pm.expect(body.tradesGenerated[0]).to.include('18/kg'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/orders/demand",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"time\": \"09:50\",\n  \"produce\": \"tomato\",\n  \"price\": 20,\n  \"quantity\": 50\n}"
            }
          }
        },
        {
          "name": "5. PUT edit_s_id again -> expect 409 (already PARTIALLY_FILLED, no longer editable)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/orders/{{edit_s_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 15,\n  \"quantity\": 10\n}"
            }
          }
        },
        {
          "name": "6. DELETE edit_s_id -> cancels its remaining 70kg, expect status CANCELLED",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('status is CANCELLED', () => pm.expect(body.status).to.eql('CANCELLED'));",
                  "pm.test('one prior trade preserved in history', () => pm.expect(body.trades.length).to.eql(1));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/orders/{{edit_s_id}}"
          }
        },
        {
          "name": "7. DELETE edit_s_id again -> expect 409 (already CANCELLED)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/orders/{{edit_s_id}}"
          }
        },
        {
          "name": "8. DELETE edit_d_id -> expect 409 (already FILLED, nothing left to cancel)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/orders/{{edit_d_id}}"
          }
        },
        {
          "name": "9. PUT unknown order id -> expect 404",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/orders/does-not-exist",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 20,\n  \"quantity\": 10\n}"
            }
          }
        }
      ]
    }
